# Pilot Screening .env example
# Copy to .env and fill in values. Do not commit real secrets.

# Firestore local safety
# Local development and tests use the Firestore emulator by default.
FIRESTORE_EMULATOR_HOST=127.0.0.1:8080

# Production Firestore credentials are prohibited locally unless an operator
# explicitly approves a diagnostic override.
ALLOW_LOCAL_PROD_FIRESTORE=false

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_IDENTITY_WEBHOOK_SECRET=

# Pricing (preferred)
STRIPE_PRICE_STARTER_MONTHLY_LIVE=
STRIPE_PRICE_STARTER_YEARLY_LIVE=
STRIPE_PRICE_PRO_MONTHLY_LIVE=
STRIPE_PRICE_PRO_YEARLY_LIVE=
STRIPE_PRICE_BUSINESS_MONTHLY_LIVE=
STRIPE_PRICE_BUSINESS_YEARLY_LIVE=
STRIPE_PRICE_STARTER_MONTHLY_TEST=
STRIPE_PRICE_STARTER_YEARLY_TEST=
STRIPE_PRICE_PRO_MONTHLY_TEST=
STRIPE_PRICE_PRO_YEARLY_TEST=
STRIPE_PRICE_BUSINESS_MONTHLY_TEST=
STRIPE_PRICE_BUSINESS_YEARLY_TEST=

# Pricing fallbacks (legacy)
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_BUSINESS_MONTHLY=
STRIPE_PRICE_BUSINESS_YEARLY=

# Screening provider
SCREENING_PROVIDER=transunion
TU_RESELLER_API_URL=
TU_RESELLER_API_KEY=
TU_WEBHOOK_SECRET=

# GCS (PDF storage)
GCS_BUCKET_NAME=

# Do not set this for local development. Use the Firestore emulator instead.
GOOGLE_APPLICATION_CREDENTIALS=

# Email
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# Frontend URLs
FRONTEND_URL=
FRONTEND_ORIGIN=
