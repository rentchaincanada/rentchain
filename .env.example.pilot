# RentChain pilot/local environment example
# Copy to .env only for local use. Do not commit real .env files.

# Firestore local safety
# Pilot development and QA runs use the Firestore emulator by default.
FIRESTORE_EMULATOR_HOST=127.0.0.1:8080

# Production Firestore credentials are prohibited locally unless an operator
# explicitly approves a diagnostic override.
ALLOW_LOCAL_PROD_FIRESTORE=false

# Do not set GOOGLE_APPLICATION_CREDENTIALS for local pilot development.
GOOGLE_APPLICATION_CREDENTIALS=
